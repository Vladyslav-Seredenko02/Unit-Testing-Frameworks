<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CalculatorTestSuite" parallel="classes" thread-count="3">

    <test name="RegressionTesting">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="DoubleSumTest"/>
            <class name="LongSumTest"/>
            <class name="DoubleSubTest"/>
            <class name="LongSubTest"/>
            <class name="DoubleMultTest"/>
            <class name="LongMultTest"/>
            <class name="DoubleDivTest"/>
            <class name="LongDivTest"/>
            <class name="DoublePowTest"/>
            <class name="DoubleSqrtTest"/>
            <class name="DoubleSinTest"/>
            <class name="DoubleCosTest"/>
            <class name="DoubleTgTest"/>
            <class name="DoubleCtgTest"/>
            <class name="BooleanIsPositiveTest"/>
            <class name="BooleanIsNegativeTest"/>
        </classes>
    </test>
</suite>